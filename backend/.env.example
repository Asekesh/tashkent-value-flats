# Copy to .env for local dev. In production set these as Railway variables.

# --- Telegram auth ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Comma-separated Telegram user ids that get role=admin on login
ADMIN_TELEGRAM_IDS=

# --- Session (JWT) ---
JWT_SECRET=change-me-to-a-long-random-string
# Set to false for local http dev so the session cookie is stored
COOKIE_SECURE=true
